{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Information",
            "Microsoft.Hosting.Lifetime": "Information",
            "ModelContextProtocol": "Information"
        }
    },
    "CodeSimilarity": {
        "Enabled": true,
        "Simplifiers": [
            {
                "Type": "WhitespaceNormalizer",
                "Enabled": true,
                "Priority": 1
            },
            {
                "Type": "CommentRemover",
                "Enabled": true,
                "Priority": 2
            }
        ],
        "Comparisons": [
            {
                "Type": "LevenshteinDistanceComparison",
                "Enabled": true,
                "Priority": 1,
                "Settings": {
                    "MaxDistance": 3,
                    "ThresholdPercent": 0.9
                }
            }
        ]
    },
    "UsageTypeFilter": {
        "IncludedUsageTypes": [
            "MethodInvocation",
            "PropertyAccess",
            "TypeReference",
            "FieldAccess",
            "ParameterType",
            "Attribute",
            "Direct",
            "VariableDeclaration",
            "GenericTypeArgument"
        ]
    }
}